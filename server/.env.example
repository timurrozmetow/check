# Скопируйте в server/.env и заполните. Комментарии [prod] — значения для VPS.
# .env в git не попадает (см. .gitignore).

# Сервер
PORT=4000
HOST=127.0.0.1
NODE_ENV=development                  # [prod] production

# База данных (MySQL 8 / MariaDB 10.4+)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root                          # [prod] отдельный пользователь, напр. directorhub
DB_PASSWORD=
DB_NAME=directorhub

# JWT — сгенерируйте: openssl rand -hex 32
JWT_SECRET=replace-with-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS (адрес фронтенда)
CORS_ORIGIN=http://localhost:5173     # [prod] https://t12.site

# Файлы. [prod] абсолютный путь вне git, чтобы git pull не трогал загрузки:
UPLOADS_DIR=./uploads                 # [prod] /var/www/directorhub/server/uploads
MAX_FILE_SIZE_MB=20

# Напоминания о дедлайнах
DEADLINE_REMINDER_HOURS=24
DEADLINE_CRON="0 * * * *"             # в кавычках — на случай, если .env кто-то source'нет

# Первичный администратор — создаётся сидером ОДИН раз (npm run db:seed).
# На обновлениях сид НЕ запускается, существующего админа не трогает.
ADMIN_EMAIL=admin@t12.site
ADMIN_PASSWORD=change-me-strong
ADMIN_NAME=Администратор
