# Сервер
PORT=4000
HOST=127.0.0.1
NODE_ENV=development

# База данных (MySQL 8 / MariaDB 10.4+)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=directorhub

# JWT
JWT_SECRET=replace-with-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS (адрес фронтенда в dev)
CORS_ORIGIN=http://localhost:5173

# Файлы
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=20
