# Nginx для DirectorHub: статика клиента (SPA) + reverse-proxy на API (PM2).
# Копия:  /etc/nginx/sites-available/directorhub  →  symlink в sites-enabled/
# Поправьте server_name и root. TLS добавит certbot автоматически:
#   sudo certbot --nginx -d t12.site -d www.t12.site

server {
    listen 80;
    listen [::]:80;
    server_name t12.site www.t12.site;

    # Собранный фронтенд (vite build → client/dist)
    root /var/www/directorhub/client/dist;
    index index.html;

    client_max_body_size 25m;        # с запасом над лимитом файла 20 МБ

    gzip on;
    gzip_comp_level 5;
    gzip_min_length 1024;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml application/wasm;

    # --- API → Fastify (PM2) на 127.0.0.1:4000 ---
    location /api/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # SSE (/api/v1/notifications/stream): без буферизации, длинный таймаут
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 24h;
    }

    # --- Загруженные файлы: ТОЛЬКО через API (там cookie-авторизация up_token). ---
    # НЕ раздавать alias'ом с диска — иначе файлы станут публичными в обход авторизации.
    location /uploads/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;     # запас на отдачу крупных файлов
    }

    # --- Хэшированная статика Vite (assets/*.js|css) — кэшируем надолго ---
    location /assets/ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # --- SPA: всё остальное → index.html ---
    location / {
        try_files $uri $uri/ /index.html;
    }

    # index.html не кэшируем, чтобы обновления фронта подхватывались сразу
    location = /index.html {
        add_header Cache-Control "no-cache";
    }
}
