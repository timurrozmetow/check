# ============================================================
# DirectorHub — переменные для docker compose (prod, t12.site)
# Скопируй в .env и заполни. НЕ коммить .env с реальными секретами.
# ============================================================

# --- База данных ---
# Пароль root MariaDB
DB_ROOT_PASSWORD=change-me-root
# Пользователь приложения и его пароль
DB_USER=directorhub
DB_PASSWORD=change-me-strong
DB_NAME=directorhub

# --- JWT ---
# Сгенерируй: openssl rand -hex 32
JWT_SECRET=replace-with-64-hex-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Адрес фронтенда (для CORS/cookie). Обычно совпадает с доменом ---
CORS_ORIGIN=https://t12.site

# --- Загрузка файлов ---
MAX_FILE_SIZE_MB=20

# --- Напоминания о дедлайнах ---
DEADLINE_REMINDER_HOURS=24
# В кавычках — иначе шелл раскроет * при чтении .env
DEADLINE_CRON="0 * * * *"

# --- Первичный администратор (создаётся один раз при первом старте) ---
ADMIN_EMAIL=admin@t12.site
ADMIN_PASSWORD=change-me-admin
ADMIN_NAME=Администратор

# --- Для init-letsencrypt.sh (выпуск TLS-сертификата) ---
DOMAIN=t12.site
# Второй домен-алиас (можно оставить). Разделяй пробелом при необходимости.
DOMAIN_ALIASES=www.t12.site
# Email для Let's Encrypt (уведомления об истечении)
LETSENCRYPT_EMAIL=you@example.com
